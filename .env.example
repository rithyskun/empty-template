# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=erp_financial

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=local-dev-secret
JWT_EXPIRES_IN=8h

# Service Ports
API_GATEWAY_PORT=8000
AUTH_SERVICE_PORT=8001
IDENTITY_SERVICE_PORT=8002
WORKFLOW_SERVICE_PORT=8003
NOTIFICATION_SERVICE_PORT=8004
PAYMENT_SERVICE_PORT=8005
SETTLEMENT_SERVICE_PORT=8006
ACCOUNTING_SERVICE_PORT=8007
RECONCILIATION_SERVICE_PORT=8008
PAYROLL_SERVICE_PORT=8009
ADVANCE_SERVICE_PORT=8010
LOAN_SERVICE_PORT=8011
INVENTORY_SERVICE_PORT=8012
PURCHASE_SERVICE_PORT=8013
SALES_SERVICE_PORT=8014
POS_SERVICE_PORT=8015
TREASURY_SERVICE_PORT=8016
REPORT_SERVICE_PORT=8017
SCHEDULER_SERVICE_PORT=8018
AUDIT_SERVICE_PORT=8021

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_METRIC_PORT=9464
OTEL_SERVICE_NAME=erp-service

# CORS
CORS_ORIGIN=*

# Active Directory / LDAP
LDAP_ENABLED=false
LDAP_URL=ldap://localhost:389
LDAP_BIND_DN=cn=admin,dc=erp,dc=local
LDAP_BIND_PASSWORD=adminpassword
LDAP_SEARCH_BASE=ou=users,dc=erp,dc=local
LDAP_USER_SEARCH_FILTER=(&(objectClass=user)(sAMAccountName={{username}}))
LDAP_GROUP_SEARCH_BASE=ou=groups,dc=erp,dc=local
LDAP_GROUP_TO_ROLE_MAPPING='{"CN=Domain Admins,CN=Users,DC=erp,DC=local":["SUPER_ADMIN"],"CN=HR Managers,OU=Groups,DC=erp,DC=local":["ADMIN"]}'

# SMTP Mail Server Configuration
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=test-user-here
SMTP_PASS=test-pass-here
SMTP_FROM="ERP Notifications" <noreply@erp.local>

