# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=erp_financial

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=local-dev-secret
JWT_EXPIRES_IN=8h

# Service Ports
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
IDENTITY_SERVICE_PORT=3002
WORKFLOW_SERVICE_PORT=3003
NOTIFICATION_SERVICE_PORT=3004
PAYMENT_SERVICE_PORT=3005
SETTLEMENT_SERVICE_PORT=3006
ACCOUNTING_SERVICE_PORT=3007
RECONCILIATION_SERVICE_PORT=3008
PAYROLL_SERVICE_PORT=3009
ADVANCE_SERVICE_PORT=3010
LOAN_SERVICE_PORT=3011
INVENTORY_SERVICE_PORT=3012
PURCHASE_SERVICE_PORT=3013
SALES_SERVICE_PORT=3014
POS_SERVICE_PORT=3015
TREASURY_SERVICE_PORT=3016
REPORT_SERVICE_PORT=3017
SCHEDULER_SERVICE_PORT=3018
AUDIT_SERVICE_PORT=3021

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_METRIC_PORT=9464
OTEL_SERVICE_NAME=erp-service

# CORS
CORS_ORIGIN=*

# Active Directory / LDAP
LDAP_ENABLED=false
LDAP_URL=ldap://localhost:389
LDAP_BIND_DN=cn=admin,dc=erp,dc=local
LDAP_BIND_PASSWORD=adminpassword
LDAP_SEARCH_BASE=ou=users,dc=erp,dc=local
LDAP_USER_SEARCH_FILTER=(&(objectClass=user)(sAMAccountName={{username}}))
LDAP_GROUP_SEARCH_BASE=ou=groups,dc=erp,dc=local
LDAP_GROUP_TO_ROLE_MAPPING='{"CN=Domain Admins,CN=Users,DC=erp,DC=local":["SUPER_ADMIN"],"CN=HR Managers,OU=Groups,DC=erp,DC=local":["ADMIN"]}'

# SMTP Mail Server Configuration
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=test-user-here
SMTP_PASS=test-pass-here
SMTP_FROM="ERP Notifications" <noreply@erp.local>

