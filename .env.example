# Database
# Supported: postgres (default), mssql, mysql, mariadb
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=erp_financial

# Read replicas (comma-separated host:port, or JSON array)
# DB_REPLICAS=192.168.1.10:5432,192.168.1.11:5432
# DB_REPLICAS=[{"host":"192.168.1.10","port":5432},{"host":"192.168.1.11","port":5432}]

# External database (enables SSL, extended timeouts)
DB_EXTERNAL=false
DB_SSL=false
DB_POOL_SIZE=20
DB_TIMEOUT=30000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=local-dev-secret
JWT_EXPIRES_IN=8h

# Body Parser
BODY_PARSER_LIMIT=1mb

# Proxy downstream response
PROXY_MAX_SOCKETS=100
PROXY_TIMEOUT_MS=30000

# Service Ports
API_GATEWAY_PORT=8000
AUTH_SERVICE_PORT=8001
IDENTITY_SERVICE_PORT=8002
WORKFLOW_SERVICE_PORT=8003
NOTIFICATION_SERVICE_PORT=8004
PAYMENT_SERVICE_PORT=8005
SETTLEMENT_SERVICE_PORT=8006
ACCOUNTING_SERVICE_PORT=8007
RECONCILIATION_SERVICE_PORT=8008
PAYROLL_SERVICE_PORT=8009
ADVANCE_SERVICE_PORT=8010
LOAN_SERVICE_PORT=8011
INVENTORY_SERVICE_PORT=8012
PURCHASE_SERVICE_PORT=8013
SALES_SERVICE_PORT=8014
POS_SERVICE_PORT=8015
TREASURY_SERVICE_PORT=8016
REPORT_SERVICE_PORT=8017
SCHEDULER_SERVICE_PORT=8018
AUDIT_SERVICE_PORT=8021

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_METRIC_PORT=9464
OTEL_SERVICE_NAME=erp-service

# CORS
CORS_ORIGIN=*

# Active Directory / LDAP
LDAP_ENABLED=false
LDAP_URL=ldap://127.0.0.1:1389
LDAP_BIND_DN=cn=admin,dc=ABA,dc=LOCAL
LDAP_BIND_PASSWORD=adminpassword
LDAP_SEARCH_BASE=dc=ABA,dc=LOCAL
LDAP_USER_SEARCH_FILTER=(&(objectClass=user)(sAMAccountName={{username}}))
LDAP_GROUP_SEARCH_BASE=ou=groups,dc=ABA,dc=LOCAL
LDAP_GROUP_TO_ROLE_MAPPING='{"CN=Domain Admins,CN=Users,DC=ABA,DC=LOCAL":["SUPER_ADMIN"],"CN=HR Managers,OU=Groups,DC=ABA,DC=LOCAL":["ADMIN"]}'

# SMTP Mail Server Configuration
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=test-user-here
SMTP_PASS=test-pass-here
SMTP_FROM="ERP Notifications" <noreply@erp.local>

# JWT
JWT_SECRET=local-dev-secret
JWT_EXPIRES_IN=8h
RSA_DECRYPTION_ENABLED=true
RSA_PRIVATE_KEY=''