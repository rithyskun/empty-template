{
  "name": "@erp/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "./scripts/dev.sh default",
    "dev:all": "./scripts/dev.sh all",
    "dev:core": "./scripts/dev.sh core",
    "dev:front": "./scripts/dev.sh frontend",
    "dev:workers": "./scripts/dev.sh workers",
    "dev:infra": "docker compose up -d postgres redis",
    "build": "nx run-many --target=build --all",
    "test": "nx run-many --target=test --all",
    "lint": "nx run-many --target=lint --all",
    "format": "nx format:write --all",
    "format:check": "nx format:check --all",
    "typecheck": "tsc -b tsconfig.json",
    "db:seed": "node database/seed/run-seed.js",
    "graph": "nx graph",
    "scan": "node scripts/code-scanner.js --severity=medium",
    "scan:high": "node scripts/code-scanner.js --severity=high",
    "scan:blocker": "node scripts/code-scanner.js --severity=blocker",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/typeorm": "^11.0.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-prometheus": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@types/compression": "^1.8.1",
    "bullmq": "^5.78.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "http-proxy-middleware": "^3.0.5",
    "ioredis": "^5.11.0",
    "jsencrypt": "^3.5.4",
    "ldapts": "^8.1.8",
    "nodemailer": "^8.0.10",
    "passport-jwt": "^4.0.1",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "typeorm": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/testing": "^11.0.0",
    "@nx/eslint-plugin": "^22.7.5",
    "@nx/js": "22.7.5",
    "@nx/nest": "22.7.5",
    "@nx/node": "22.7.5",
    "@nx/web": "22.7.5",
    "@nx/webpack": "22.7.5",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@swc/jest": "0.2.39",
    "@types/http-proxy-middleware": "^0.19.3",
    "@types/jest": "30.0.0",
    "@types/node": "20.19.9",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "husky": "^9.1.7",
    "jest": "30.2.0",
    "jest-environment-node": "30.2.0",
    "ldapjs": "^2.3.3",
    "nx": "22.7.5",
    "prettier": "^3.8.1",
