echo "🛡️ Running pre-commit quality gates..."

# 1. Format check
echo "✨ Checking code formatting..."
npm run format:check || {
  echo "❌ Formatting check failed! Please run 'npm run format' to auto-format your files before committing."
  exit 1
}

# 2. TypeScript compilation check
echo "⚙️ Checking TypeScript compilation..."
npm run typecheck || {
  echo "❌ TypeScript typecheck failed! Please resolve all type compilation errors before committing."
  exit 1
}

# 3. Lint check
echo "🔍 Running ESLint checks..."
npm run lint || {
  echo "❌ ESLint checks failed! Please resolve all lint errors before committing."
  exit 1
}

echo "✅ All quality gates passed! Committing code..."
